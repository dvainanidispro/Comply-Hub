<div class="container-fluid">
    <div class="row">
        <!-- Breadcrumb -->
        <div class="col-12 mb-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/users">Χρήστες</a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{#if isNew}}Νέος Χρήστης{{else}}{{userDetails.name}}{{/if}}</li>
                </ol>
            </nav>
        </div>
        
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title">
                        {{#if isNew}}
                        <i class="ti-plus me-2"></i>
                        Νέος Χρήστης
                        {{else}}
                        <i class="ti-pencil me-2"></i>
                        Επεξεργασία Χρήστη
                        {{/if}}
                    </h4>
                </div>
                <div class="card-body">
                    <form id="form">
                        {{#unless isNew}}
                        <input type="hidden" id="editUserId" name="id" value="{{userDetails.id}}">
                        {{/unless}}
                        
                        <div class="row">
                            {{#unless isNew}}
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">ID Χρήστη:</label>
                                <p class="form-control-plaintext text-muted">{{userDetails.id}}</p>
                            </div>
                            <div class="col-md-6 mb-3"></div>
                            {{/unless}}
                            <div class="col-md-6 mb-3">
                                <label for="editUserEmail" class="form-label fw-bold">Email *</label>
                                <input type="email" class="form-control" id="editUserEmail" name="email" value="{{userDetails.email}}" autocomplete="new-email" required>
                                <div class="form-text">Χρησιμοποιείται για την είσοδο στην εφαρμογή</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="editUserName" class="form-label fw-bold">Όνομα</label>
                                <input type="text" class="form-control" id="editUserName" name="name" value="{{userDetails.name}}" autocomplete="off">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="editUserRole" class="form-label fw-bold">Ρόλος *</label>
                                <select class="form-select" id="editUserRole" name="role" required {{#if (eq userDetails.email @root.user.email)}}disabled{{/if}}>
                                    {{#each roles}}
                                        <option value="{{this.name}}" data-can-have-organization="{{this.canHaveOrganization}}" {{#if (eq this.name ../userDetails.role)}}selected{{/if}}>{{this.displayName}}</option>
                                    {{/each}}
                                </select>
                                {{#if (eq userDetails.email @root.user.email)}}
                                <div class="form-text">Δεν μπορείτε να αλλάξετε τον δικό σας ρόλο</div>
                                {{/if}}
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="editUserOrganization" class="form-label fw-bold">Οργανισμός</label>
                                <select class="form-select" id="editUserOrganization" name="organizationId" disabled>
                                    <option value="">Όλα</option>
                                    {{#each organizations}}
                                        <option value="{{this.id}}" {{#if (eq this.id ../userDetails.organizationId)}}selected{{/if}}>{{this.name}}</option>
                                    {{/each}}
                                </select>
                                <div class="form-text">Ο Οργανισμός στον οποίο ανήκει ο χρήστης</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="editUserPassword" class="form-label fw-bold">{{#if isNew}}Password *{{else}}Νέο Password{{/if}}</label>
                                <span class="password-toggle"><i class="bi bi-eye"></i></span>
                                <input type="password" class="form-control" id="editUserPassword" name="password" pattern="^(?=.*[A-Za-z])(?=.*\d)(?=.*[^A-Za-z\d]).{8,}$" title="Το password πρέπει να περιέχει τουλάχιστον 8 χαρακτήρες, ένα λατινικό γράμμα, έναν αριθμό και ένα σύμβολο." autocomplete="new-password" {{#if isNew}}required{{/if}}>
                                <div class="form-text">{{#if isNew}}Ο κωδικός πρέπει να περιέχει τουλάχιστον 8 χαρακτήρες, ένα λατινικό γράμμα, έναν αριθμό και ένα σύμβολο{{else}}Να παραμείνει κενό αν δεν επιθυμείτε την αλλαγή του{{/if}}</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="editUserActive" class="form-label fw-bold">Κατάσταση *</label>
                                <select class="form-select" id="editUserActive" name="active" {{#if (eq userDetails.email @root.user.email)}}disabled{{/if}}>
                                    <option value="true" {{#unless (eq userDetails.active false)}}selected{{/unless}}>Ενεργός</option>
                                    <option value="false" {{#if (eq userDetails.active false)}}selected{{/if}}>Ανενεργός</option>
                                </select>
                                {{#if (eq userDetails.email @root.user.email)}}
                                <div class="form-text">Δεν μπορείτε να αλλάξετε την κατάσταση του δικού σας λογαριασμού</div>
                                {{else}}
                                <div class="form-text">Καθορίζει αν ο χρήστης μπορεί να πραγματοποιήσει είσοδο στην Εφαρμογή</div>
                                {{/if}}
                            </div>
                        </div>
                        
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="d-flex g-2">
                                    <button type="submit" class="btn btn-success btn-icon">
                                        <bootstrap-icon icon="check-circle-fill"></bootstrap-icon>
                                        <div>{{#if isNew}}Δημιουργία{{else}}Αποθήκευση{{/if}}</div>
                                    </button>
                                    <a href="/admin/users" class="btn btn-secondary btn-icon">
                                        <bootstrap-icon icon="x-circle-fill"></bootstrap-icon>
                                        <div>Ακύρωση</div>
                                    </a>
                                    <bootstrap-spinner class="d-none"></bootstrap-spinner>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="ti-settings me-2"></i>
                        Άλλες Ενέργειες
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-grid">
                        {{#unless isNew}}
                        {{#unless (eq userDetails.email @root.user.email)}}
                        <button type="button" class="btn btn-danger delete-user-btn"
                                data-user-id="{{userDetails.id}}" 
                                data-user-name="{{userDetails.name}}">
                            <i class="ti-trash me-1"></i>
                            Διαγραφή Χρήστη
                        </button>
                        
                        <hr>
                        {{/unless}}
                        {{/unless}}
                        
                        <a href="/admin/users" class="btn btn-secondary">
                            <i class="ti-arrow-left me-1"></i>
                            Επιστροφή στη Λίστα Χρηστών
                        </a>
                    </div>
                </div>
            </div>
            
            {{#unless isNew}}
            <!-- Πληροφορίες δραστηριότητας -->
            <div class="card mt-3">
                <div class="card-header">
                    <h6 class="card-title mb-0">
                        <i class="ti-info me-2"></i>
                        Πληροφορίες Λογαριασμού
                    </h6>
                </div>
                <div class="card-body">
                    <small class="text-muted">
                        <p><strong>Δημιουργία λογαριασμού:</strong><br>
                        {{date userDetails.createdAt}}</p>
                        
                        <p><strong>Τελευταία ενημέρωση:</strong><br>
                        {{date userDetails.updatedAt}}</p>
                        
                    </small>
                </div>
            </div>
            {{/unless}}
        </div>
    </div>
</div>

<script type="module">
const isNew = {{isNew}};

document.addEventListener('DOMContentLoaded', function() {

    // Λογική για enable/disable του organization field με βάση τον επιλεγμένο ρόλο
    function updateOrganizationField() {
        const selectedOption = Q('#editUserRole').options[Q('#editUserRole').selectedIndex];
        const canHaveOrganization = selectedOption.dataset.canHaveOrganization === 'true';
        
        if (canHaveOrganization) {
            Q('#editUserOrganization').disabled = false;
        } else {
            Q('#editUserOrganization').disabled = true;
            Q('#editUserOrganization').value = '';
        }
    }
    
    // Ενημέρωση κατά τη φόρτωση της σελίδας
    updateOrganizationField();
    // Ενημέρωση με κάθε αλλαγή του ρόλου
    Q('#editUserRole').on('change', updateOrganizationField);
    
    // Form για επεξεργασία/δημιουργία χρήστη
    Q('#form').on('submit', async function(e) {
        e.preventDefault();
        await submitData(
            this, 
            '/admin/users', 
            isNew ? 'POST' : 'PUT',
            isNew ? '/admin/users' : null
        );
    });
    
    {{#unless isNew}}
    // Button για διαγραφή χρήστη
    Q('.delete-user-btn').on('click', async function() {
        await deleteEntity(
            `Είστε σίγουροι ότι θέλετε να διαγράψετε τον χρήστη "${this.dataset.userName}";`,
            '/admin/users'
        );
    });
    {{/unless}}
});
</script>
